generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id        String         @id @default(uuid())
  name      String
  slug      String         @unique
  createdAt DateTime       @default(now())
  orders    OrderEvent[]
  payments  PaymentEvent[]
  scans     ScanEvent[]
}

model WaiterCalls {
  id           String    @id
  restaurantId String
  tableNumber  Int
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  reachedAt    DateTime?
}

model OrderEvent {
  id            String     @id @default(uuid())
  restaurantId  String
  tableNumber   String
  items         Json
  totalPrice    Int
  createdAt     DateTime   @default(now())
  paymentStatus String     @default("unpaid")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([createdAt])
}

model PaymentEvent {
  id           String     @id @default(uuid())
  restaurantId String
  tableNumber  String
  amount       Int
  items        Json
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([createdAt])
}

model ScanEvent {
  id           String     @id @default(uuid())
  restaurantId String
  tableNumber  String?
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([createdAt])
}
